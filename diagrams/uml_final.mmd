classDiagram
    %% PawPal+ FINAL architecture — matches pawpal_system.py after Phases 2-4.
    %% (diagrams/uml.mmd is the Phase 1 draft kept for comparison.)

    class Owner {
        +str name
        +int available_minutes
        +str preferred_start
        +List~Pet~ pets
        +add_pet(pet Pet) None
        +find_pet(pet_name str) Pet
        +add_task(pet_name str, task Task) None
        +all_tasks() List~Task~
    }

    class Pet {
        +str name
        +str species
        +str breed
        +int age_years
        +List~Task~ tasks
        +add_task(task Task) None
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +str category
        +str recurrence
        +str preferred_time
        +bool completed
        +date due_date
        +priority_rank() int
        +mark_complete() None
        +next_occurrence() Task
    }

    class ScheduledTask {
        +Task task
        +str start_time
        +str end_time
        +str reason
    }

    class Scheduler {
        +int available_minutes
        +str day_start
        +sort_tasks(tasks List~Task~) List~Task~
        +sort_by_time(tasks List~Task~) List~Task~
        +filter_by_status(tasks List~Task~, completed bool) List~Task~
        +filter_by_pet(owner Owner, pet_name str) List~Task~
        +expand_recurring(tasks List~Task~, day str) List~Task~
        +mark_task_complete(task Task) Task
        +build_plan(tasks List~Task~) List~ScheduledTask~
        +detect_conflicts(tasks List~Task~) List~str~
        +explain_plan(plan List~ScheduledTask~) str
    }

    Owner "1" o-- "many" Pet : has
    Pet "1" o-- "many" Task : has
    Scheduler ..> Owner : reads pets from
    Scheduler ..> Task : sorts / filters
    Scheduler ..> ScheduledTask : produces
    ScheduledTask "1" --> "1" Task : wraps
